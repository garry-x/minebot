# Bot Server Configuration
HOST=0.0.0.0
PORT=9500
LOG_DIR=logs
BOT_PID_FILE=bot_server.pid
BOT_LOG_FILE=bot_server.log

# Minecraft Server Configuration
MINECRAFT_SERVER_HOST=localhost
MINECRAFT_SERVER_PORT=25565
MINECRAFT_SERVER_DIR=resources/java-1.21.11
MINECRAFT_JAR_PATH=minecraft_server.1.21.11.jar
MINECRAFT_PID_FILE=logs/minecraft_server.pid
MINECRAFT_MAX_MEMORY=1G
MINECRAFT_SERVER_ARGS=nogui

# Bot Server Connection (for cli and other services)
BOT_SERVER_HOST=localhost
BOT_SERVER_PORT=9500

# LLM / AI Configuration
VLLM_URL=http://localhost:8000
LLM_SERVICE_URL=http://localhost:8000
USE_FALLBACK=false

# Frontend Configuration
FRONTEND_PORT=3000
API_TARGET=http://localhost:9500

# Frontend Default Values (for ConfigPanel)
REACT_APP_DEFAULT_HOST=0.0.0.0
REACT_APP_DEFAULT_PORT=9500
REACT_APP_AUTO_RECONNECT_RETRIES=3
REACT_APP_AUTO_RECONNECT_DELAY=5000
REACT_APP_BROADCAST_INTERVAL=5000
REACT_APP_SERVER_STATE_SAVE_INTERVAL=30000
REACT_APP_BOT_STALE_CLEANUP_DAYS=7
REACT_APP_DEFAULT_MC_HOST=localhost
REACT_APP_DEFAULT_MC_PORT=25565
REACT_APP_LLM_SERVICE_URL=http://localhost:8080
REACT_APP_VLLM_URL=http://localhost:8080
REACT_APP_USE_FALLBACK=true
REACT_APP_DEFAULT_FRONTEND_PORT=3000
REACT_APP_DEFAULT_BUILDING_WIDTH=10
REACT_APP_DEFAULT_BUILDING_LENGTH=10
REACT_APP_DEFAULT_BUILDING_HEIGHT=6
REACT_APP_DEFAULT_BUILDING_BLOCK_TYPE=stone
REACT_APP_DEFAULT_GATHERING_RADIUS=30

# Timing Configuration (milliseconds)
BROADCAST_INTERVAL=5000
SERVER_STATE_SAVE_INTERVAL=30000
AUTO_RECONNECT_DELAY=5000
AUTO_RECONNECT_RETRIES=3
BOT_STATUS_CHECK_TIMEOUT=2000
DATABASE_BUSY_TIMEOUT=5000
STATUS_UPDATE_INTERVAL=3000

# Bot Behavior Configuration
MAX_BLOCK_FIND_DISTANCE=32
WAIT_FOR_CONDITION_TIMEOUT=10000
WAIT_RETRY_INTERVAL=500
MAX_OPERATION_RETRIES=3
BASE_RETRY_DELAY=1000
MAX_PATHFIND_RETRIES=5
PATHFINDER_TIMEOUT=30000
FOLLOW_TIMEOUT=30000
MINECRAFT_DAYTIME_THRESHOLD=13000
EXPERIENCE_FLUSH_INTERVAL=30000
BOT_STALE_CLEANUP_DAYS=30

# Default Building Configuration (for new bots)
DEFAULT_BUILDING_WIDTH=5
DEFAULT_BUILDING_LENGTH=5
DEFAULT_BUILDING_HEIGHT=3
DEFAULT_BUILDING_BLOCK_TYPE=oak_planks
DEFAULT_GATHERING_RADIUS=10
DEFAULT_GATHERING_TARGETS=oak_log,cobblestone,iron_ore,coal_ore

# Security
SESSION_SECRET=your_session_secret_here
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Logging
LOG_LEVEL=debug

# Development
NODE_ENV=development
