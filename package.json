{
  "name": "minecraft-ai-robot",
  "version": "1.0.0",
  "description": "AI Robot System for Minecraft Java Server",
  "main": "bot_server.js",
  "bin": {
    "minebot": "./cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:js": "node build.js",
    "start": "node dist/bot_server.js",
    "dev": "nodemon --exec ts-node bot_server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "cli": "node dist/cli.js",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "canvas": "^3.2.3",
    "commander": "^12.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mineflayer": "^4.15.0",
    "mineflayer-pathfinder": "^1.7.0",
    "oh-my-openagent-linux-arm64": "^3.14.0",
    "prismarine-viewer": "^1.25.0",
    "sqlite3": "^5.1.6",
    "vec3": "^0.1.10",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.28.0",
    "jest": "^29.6.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
