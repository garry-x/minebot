{
  "name": "minecraft-ai-robot",
  "version": "1.0.0",
  "description": "AI Robot System for Minecraft Java Server",
  "main": "bot_server.js",
  "bin": {
    "minebot": "./cli.js"
  },
  "scripts": {
    "start": "node bot_server.js",
    "dev": "nodemon bot_server.js",
    "frontend:dev": "cd frontend && npm start",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "cd frontend && npm run build",
    "start:prod": "npm run build && NODE_ENV=production node bot_server.js",
    "cli": "node cli.js"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mineflayer": "^4.15.0",
    "mineflayer-pathfinder": "^1.7.0",
    "sqlite3": "^5.1.6",
    "vec3": "^0.1.10",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "jest": "^29.6.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
